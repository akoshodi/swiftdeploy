worker_processes auto;

events {
    worker_connections 1024;
}

http {
    log_format swiftdeploy '$time_iso8601 | $status | ${request_time}s | $upstream_addr | $request';

    access_log /var/log/nginx/access.log swiftdeploy;
    error_log /var/log/nginx/error.log warn;

    upstream swiftdeploy_upstream {
        server app:${SERVICE_PORT};
    }

    server {
        listen ${NGINX_PORT};
        server_name _;

        proxy_read_timeout ${PROXY_TIMEOUT};
        proxy_send_timeout ${PROXY_TIMEOUT};
        proxy_connect_timeout ${PROXY_TIMEOUT};

        add_header X-Deployed-By "swiftdeploy" always;
        add_header X-Mode $upstream_http_x_mode always;

        error_page 502 = @error_502;
        error_page 503 = @error_503;
        error_page 504 = @error_504;

        location / {
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_pass http://swiftdeploy_upstream;
        }

        location @error_502 {
            default_type application/json;
            return 502 '{"error":"bad_gateway","code":502,"service":"${SERVICE_NAME}","contact":"${CONTACT}"}';
        }

        location @error_503 {
            default_type application/json;
            return 503 '{"error":"service_unavailable","code":503,"service":"${SERVICE_NAME}","contact":"${CONTACT}"}';
        }

        location @error_504 {
            default_type application/json;
            return 504 '{"error":"gateway_timeout","code":504,"service":"${SERVICE_NAME}","contact":"${CONTACT}"}';
        }
    }
}
